# Mdict Server 配置文件
# 复制此文件为 .env 并修改配置

# 服务器配置
SERVER_ADDR=0.0.0.0
SERVER_PORT=8080

# 数据目录
DICT_DIR=./dicts
DATA_DIR=./data

# 管理员账户（首次启动时自动生成，建议手动设置）
ADMIN_USER=admin
ADMIN_PASS=your-secure-password

# JWT 密钥（至少 32 字符）
JWT_SECRET=your-secret-key-at-least-32-characters

# Token 有效期
JWT_ACCESS_TTL=2h
JWT_REFRESH_TTL=168h

# Agent Skill 服务器地址
SKILL_SERVER_URL=http://localhost:8080

# 上传文件大小限制
MAX_UPLOAD_SIZE=500MB

# 请求限流（每分钟，0=不限制）
RATE_LIMIT=100

# 日志级别 (debug/info/warn/error)
LOG_LEVEL=info

# 日志格式 (json/text)
LOG_FORMAT=json

# 跨域配置（逗号分隔）
CORS_ORIGINS=*
